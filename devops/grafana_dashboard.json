{
  "dashboard": {
    "id": null,
    "title": "VelDB Overview",
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "type": "stat",
        "title": "Backend API",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "up{job=\"veldb-backend\"}",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "auto",
          "textMode": "value",
          "colorMode": "value",
          "graphMode": "none",
          "justify": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "red", "value": 0.5 }
              ]
            },
            "unit": "short"
          },
          "overrides": []
        }
      },
      {
        "type": "stat",
        "title": "Rust Engine",
        "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "up{job=\"veldb-rust-engine\"}",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "auto",
          "textMode": "value",
          "colorMode": "value",
          "graphMode": "none",
          "justify": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "red", "value": 0.5 }
              ]
            },
            "unit": "short"
          },
          "overrides": []
        }
      },
      {
        "type": "graph",
        "title": "Request Rate (Backend)",
        "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{endpoint}}",
            "refId": "A"
          }
        ],
        "options": {
          "tooltip": {
            "mode": "single",
            "sort": "none"
          },
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        }
      },
      {
        "type": "graph",
        "title": "Database Connections",
        "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "pg_stat_activity_count",
            "legendFormat": "{{datastore}}",
            "refId": "A"
          }
        ],
        "options": {
          "tooltip": {
            "mode": "single",
            "sort": "none"
          },
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        }
      }
    ],
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    }
  },
  "overwrite": true
}